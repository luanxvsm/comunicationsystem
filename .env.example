# Banco de Dados (Neon, Supabase ou PostgreSQL local)
# Exemplo Neon: postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/comunicacao?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/comunicacao"

# SendGrid
SENDGRID_API_KEY="SG.xxxx"
SENDGRID_FROM_EMAIL="noreply@seudominio.com"

# Twilio
TWILIO_ACCOUNT_SID="ACxxxx"
TWILIO_AUTH_TOKEN="xxxx"
TWILIO_PHONE_NUMBER="+15005550006"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# Segurança do Webhook (HMAC-SHA256)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET="um-segredo-forte-aqui"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
